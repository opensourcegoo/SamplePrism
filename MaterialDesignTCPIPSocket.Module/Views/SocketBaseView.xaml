             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MaterialDesignTCPIPSocket.Module.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Button Content="SocketListen1" Command="{Binding SocketListen1Command}" Background="Red" HorizontalAlignment="Left" Margin="98,50,0,0" VerticalAlignment="Top"/>
        <TextBlock HorizontalAlignment="Left" Height="54" Foreground="Blue" FontSize="15" TextWrapping="Wrap" Text="{Binding InfoName}" VerticalAlignment="Top" Width="190" Margin="32,87,0,0"/>
    </Grid>
</UserControl>

    